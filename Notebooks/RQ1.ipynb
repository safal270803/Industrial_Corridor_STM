   "source": [
    "import geemap\n",
    "import ee \n",
    "import os\n",
    "import pandas as pd\n",
    "import geopandas as gpd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e8ab4b36-48d7-4085-8886-2ad5685de0de",
   "metadata": {},
   "outputs": [],
   "source": [
    "geemap.ee_initialize()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "be345cf1-1d8e-46f2-936b-970f1e242656",
   "metadata": {},
   "outputs": [],
   "source": [
    "Map = geemap.Map()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e6b9d0b1-077e-4363-b255-79b83b3accb4",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Define the Relative Path\n",
    "# '..' means go up one folder from where this notebook is saved\n",
    "file_path = os.path.join('..', 'data', 'processed', 'Dholera_Taluk.geojson')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "8654a01f-7dd0-48b2-b9b1-a67863ce9cce",
   "metadata": {},
   "outputs": [],
   "source": [
    "roi = geemap.geojson_to_ee(file_path)\n",
    "Map.addLayer(roi, {'color': 'blue', 'width': 2}, 'Dholera Taluka Boundary')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "38ac5e71-1c65-4796-91be-268892fda355",
   "metadata": {},
   "source": [
    "I chose Oct to Dec, 2025 time period, because at this time, soil doesn't reflect much of SWIR compared to summer, so the chances of false positive is lesser compared to data from summer or during the monsoon period."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "4d79eb35-d0bc-49fc-a028-8d1b787aa453",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load and Filter Sentinel-2 Surface Reflectance (2026)\n",
    "# We use the Harmonized collection for consistency\n",
    "s2 = ee.ImageCollection(\"COPERNICUS/S2_SR_HARMONIZED\") \\\n",
    "    .filterBounds(roi) \\\n",
    "    .filterDate('2025-10-01', '2025-12-31') \\\n",
    "    .filter(ee.Filter.lt('CLOUDY_PIXEL_PERCENTAGE', 5)) \\\n",
    "    .median() \\\n",
    "    .clip(roi)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "9adcf5a3-432b-4c61-b8a4-4b926d41fbbf",
   "metadata": {},
   "outputs": [],
   "source": [
    "#Visualising this: \n",
    "vis = {\n",
    "    \"min\": 0.0,\n",
    "    \"max\": 3000,\n",
    "    \"bands\": [\"B4\", \"B3\", \"B2\"],\n",
    "}\n",
    "Map.centerObject(roi, 10)\n",
    "Map.addLayer(s2, vis, \"Sentinel-2\")\n",
    "Map\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "a45ade2f-3a6b-4db5-b652-b02409a57d98",
   "metadata": {},
   "source": [
    "Program to Check NDBI\n",
    "\n",
    "In the red/orange areas, you are likely looking at residential or commercial zones."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "922ce3b2-93b5-4a05-bf6f-3d9fd6b1eeeb",
   "metadata": {},
   "outputs": [],
   "source": [
    "# NDBI: Built-up/Urban Index\n",
    "def get_ndbi(image):\n",
    "    ndbi = image.normalizedDifference(['B11', 'B8']).rename('NDBI')\n",
    "    return ndbi\n",
    "\n",
    "# --- Map 1: NDBI (Built-up / Urban) ---\n",
    "Map_NDBI = geemap.Map()\n",
    "Map_NDBI.centerObject(roi, 10)\n",
    "ndbi_params = {'min': -0.5, 'max': 0.5, 'palette': ['white', 'orange', 'red']}\n",
    "\n",
    "Map_NDBI.addLayer(get_ndbi(s2), ndbi_params, 'NDBI (Urban)')\n",
    "Map_NDBI.add_colorbar(vis_params=ndbi_params, label=\"NDBI Value\", orientation=\"horizontal\")\n",
    "print(\"Displaying NDBI Map...\")\n",
    "display(Map_NDBI)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "48c93317-ae5a-415d-be6c-344087bfbb14",
   "metadata": {},
   "source": [
    "Program to check MNDWI \n",
    "\n",
    "Look for the deep blue pixels; those will be your lakes, rivers, or reservoirs."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "aaf46b48-a348-4b59-8806-38cc2a656b64",
   "metadata": {},
   "outputs": [],
   "source": [
    "# MNDWI: Water Index\n",
    "def get_mndwi(image):\n",
    "    mndwi = image.normalizedDifference(['B3', 'B11']).rename('MNDWI')\n",
    "    return mndwi\n",
    "\n",
    "# --- Map 2: MNDWI (Water Index) ---\n",
    "Map_MNDWI = geemap.Map()\n",
    "Map_MNDWI.centerObject(roi, 10)\n",
    "mndwi_params = {'min': -0.5, 'max': 0.5, 'palette': ['white', 'lightblue', 'blue']}\n",
    "\n",
    "Map_MNDWI.addLayer(get_mndwi(s2), mndwi_params, 'MNDWI (Water)')\n",
    "Map_MNDWI.add_colorbar(vis_params=mndwi_params, label=\"MNDWI Value\", orientation=\"horizontal\")\n",
    "print(\"Displaying MNDWI Map...\")\n",
    "display(Map_MNDWI)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "a0f92776-b21c-487c-acb3-f65df36659da",
   "metadata": {},
   "source": [
    "Program to check SAVI\n",
    "\n",
    "The vibrant green represents healthy biomass. If you compare this to a standard NDVI, you'll notice it handles the edges of fields (where soil is visible) much more accurately."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "47b0b0db-2490-49ad-bf3d-a578705c5be4",
   "metadata": {},
   "outputs": [],
   "source": [
    "# SAVI: Soil Adjusted Vegetation Index\n",
    "def get_savi(image):\n",
    "    savi = image.expression(\n",
    "        '((NIR - RED) * 1.5) / (NIR + RED + 0.5)', {\n",
    "            'NIR': image.select('B8'),\n",
    "            'RED': image.select('B4')\n",
    "        }).rename('SAVI')\n",
    "    return savi\n",
    "\n",
    "# --- Map 3: SAVI (Soil Adjusted Vegetation) ---\n",
    "Map_SAVI = geemap.Map()\n",
    "Map_SAVI.centerObject(roi, 10)\n",
    "savi_params = {'min': 0, 'max': 1, 'palette': ['brown', 'yellow', 'green']}\n",
    "\n",
    "Map_SAVI.addLayer(get_savi(s2), savi_params, 'SAVI (Vegetation)')\n",
    "Map_SAVI.add_colorbar(vis_params=savi_params, label=\"SAVI Value\", orientation=\"horizontal\")\n",
    "print(\"Displaying SAVI Map...\")\n",
    "display(Map_SAVI)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "0fe250b2-1659-445e-bd3b-a5ea87f061dc",
   "metadata": {},
   "source": [
    "Defining Indexes for Build-up Estimation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "0a33eaaf-0929-4437-b2fb-224597c621dc",
   "metadata": {},
   "outputs": [],
   "source": [
    "# 2. Define Index Functions\n",
    "def calculate_indices(image):\n",
    "    # Band aliases for Sentinel-2\n",
    "    # B11=SWIR1, B8=NIR, B3=Green, B4=Red\n",
    "    res = image.expression(\n",
    "        '(SWIR1 - NIR) / (SWIR1 + NIR)', {\n",
    "            'SWIR1': image.select('B11'),\n",
    "            'NIR': image.select('B8')\n",
    "        }).rename('NDBI')\n",
    "    \n",
    "    mndwi = image.expression(\n",
    "        '(Green - SWIR1) / (Green + SWIR1)', {\n",
    "            'Green': image.select('B3'),\n",
    "            'SWIR1': image.select('B11')\n",
    "        }).rename('MNDWI')\n",
    "    \n",
    "    savi = image.expression(\n",
    "        '((NIR - Red) * 1.5) / (NIR + Red + 0.5)', {\n",
    "            'NIR': image.select('B8'),\n",
    "            'Red': image.select('B4')\n",
    "        }).rename('SAVI')\n",
    "        \n",
    "    return image.addBands([res, mndwi, savi])\n",
    "\n",
    "# Apply the indices\n",
    "processed_img = calculate_indices(s2)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "19b600b5-700c-4a71-b8f7-078fda74ea0d",
   "metadata": {},
   "source": [
    "Program to check and fine-tune the logic of Urban Build-up measurement"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "28d5dd83-d8cc-48cd-95a0-159c6b928890",
   "metadata": {},
   "outputs": [],
   "source": [
    "# 3. Create the \"Clean\" Built-up Mask (The Logic)\n",
    "# Thresholds: \n",
    "# NDBI > 0 (Built-up typically positive)\n",
    "# MNDWI < 0 (Exclude water/moist salt pans)\n",
    "# SAVI < 0.2 (Exclude vegetation)\n",
    "built_up_mask = processed_img.expression(\n",
    "    '(NDBI > 0.05) && (MNDWI < 0) && (SAVI < 0.18)', {\n",
    "        'NDBI': processed_img.select('NDBI'),\n",
    "        'MNDWI': processed_img.select('MNDWI'),\n",
    "        'SAVI': processed_img.select('SAVI')\n",
    "    }).rename('BuiltUp')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "3d00f209-1571-42aa-aa28-d7bae88bed6c",
   "metadata": {},
   "outputs": [],
   "source": [
    "# 4. Visualization\n",
    "Map = geemap.Map()\n",
    "Map.centerObject(roi, 11)\n",
    "\n",
    "# True Color for Reference\n",
    "Map.addLayer(s2, {'bands': ['B4', 'B3', 'B2',], 'min': 0, 'max': 3000}, 'S2 True Color (2025)')\n",
    "\n",
    "# The Result: 1 = White (Built-up), 0 = Black (Everything Else)\n",
    "Map.addLayer(built_up_mask, {'min': 0, 'max': 1, 'palette': ['black', 'white']}, 'Clean Built-up Layer')\n",
    "\n",
    "Map"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "b4891acb-9f40-4058-8f3c-4bc8c9caf4d0",
   "metadata": {},
   "source": [
    "Exporting Image to google drive (Run this code, if you genuinely want the build-up data in your drive), otherwise simply skip this code block."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e18cb6b0-dac2-428d-aa25-a4de90a98c7a",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Export the 2025 Built-up Mask to Google Drive\n",
    "task = ee.batch.Export.image.toDrive(\n",
    "    image= built_up_mask.toByte(), # Convert to 0-1 byte for smaller file size\n",
    "    description='Dholera_Builtup_Mask_2025',\n",
    "    folder='export',\n",
    "    fileNamePrefix='dholera_builtup_2025',\n",
    "    region=roi.geometry(),\n",
    "    scale=10, # Sentinel-2 resolution\n",
    "    crs='EPSG:32643', # Export in UTM 43N for direct QGIS use\n",
    "    maxPixels=1e13\n",
    ")\n",
    "task.start()\n",
    "print(\" Export started! Check your Google Drive 'Dholera_Project' folder in a few minutes.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "8558f11d-9d8d-4312-8c24-bf0f32743391",
   "metadata": {},
   "source": [
    "I am providing the geojson file for important_roads, you can access that in data/processed folder. \n",
    "But, if you want latest road data, you can use QGIS OSM Pluggin to extract roads: In highway (motorway|trunk|primary|secondary|tertiary) roads are extracted. These are the most important roads in our analysis ensuring we utlise the most important roads only. "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "1b6cb860-5171-427d-a6ab-9e3f5bf61981",
   "metadata": {},
   "outputs": [],
   "source": [
    "# 1: Local Infrastructure Ingestion ---\n",
    "# Path to your manually verified roads from QGIS\n",
    "roads_path = os.path.join('..', 'data', 'Processed', 'important_roads.geojson')\n",
    "\n",
    "if os.path.exists(roads_path):\n",
    "    print(f\" Loading verified infrastructure from: {roads_path}\")\n",
    "    \n",
    "    # 1. Load the local GeoJSON into a GeoDataFrame\n",
    "    major_roads_gdf = gpd.read_file(roads_path)\n",
    "    \n",
    "    # Ensure it is in EPSG:4326 before sending to GEE\n",
    "    if major_roads_gdf.crs != \"EPSG:4326\":\n",
    "        major_roads_gdf = major_roads_gdf.to_crs(\"EPSG:4326\")\n",
    "    \n",
    "    # 2. Upload to GEE Cloud\n",
    "    ee_roads = geemap.geopandas_to_ee(major_roads_gdf)\n",
    "    print(f\" {len(major_roads_gdf)} road segments uploaded to GEE.\")\n",
    "else:\n",
    "    print(\" ERROR: File not found. Please check the path.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "324d6300-621e-4ac7-a16a-ba2ef031bd38",
