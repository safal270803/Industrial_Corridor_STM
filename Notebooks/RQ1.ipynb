    "# ============================================================\n",
    "# Built-up Area Statistics: Growth, Loss & Net Change\n",
    "# ============================================================\n",
    "\n",
    "# Step 1: Pixel Area Image (in square meters)\n",
    "pixel_area = ee.Image.pixelArea()  # Each pixel's area in m²\n",
    "\n",
    "# ============================================================\n",
    "# Step 2: Area Calculations\n",
    "# ============================================================\n",
    "\n",
    "# --- Total Built-up Area in 2016 ---\n",
    "area_2016 = mask_2016.eq(1) \\\n",
    "    .multiply(pixel_area) \\\n",
    "    .reduceRegion(\n",
    "        reducer=ee.Reducer.sum(),\n",
    "        geometry=roi,\n",
    "        scale=10,          # Sentinel-2 native resolution\n",
    "        maxPixels=1e13\n",
    "    )\n",
    "\n",
    "# --- Total Built-up Area in 2025 ---\n",
    "area_2025 = built_up_mask.eq(1) \\\n",
    "    .multiply(pixel_area) \\\n",
    "    .reduceRegion(\n",
    "        reducer=ee.Reducer.sum(),\n",
    "        geometry=roi,\n",
    "        scale=10,\n",
    "        maxPixels=1e13\n",
    "    )\n",
    "\n",
    "# --- New Growth (0 in 2016 → 1 in 2025) ---\n",
    "new_growth_mask = mask_2016.eq(0).And(built_up_mask.eq(1))\n",
    "area_new_growth = new_growth_mask \\\n",
    "    .multiply(pixel_area) \\\n",
    "    .reduceRegion(\n",
    "        reducer=ee.Reducer.sum(),\n",
    "        geometry=roi,\n",
    "        scale=10,\n",
    "        maxPixels=1e13\n",
    "    )\n",
    "\n",
    "# --- Lost Built-up (1 in 2016 → 0 in 2025) ---\n",
    "lost_mask = mask_2016.eq(1).And(built_up_mask.eq(0))\n",
    "area_lost = lost_mask \\\n",
    "    .multiply(pixel_area) \\\n",
    "    .reduceRegion(\n",
    "        reducer=ee.Reducer.sum(),\n",
    "        geometry=roi,\n",
    "        scale=10,\n",
    "        maxPixels=1e13\n",
    "    )\n",
    "\n",
    "# --- Stable Built-up (1 in both years) ---\n",
    "stable_mask = mask_2016.eq(1).And(built_up_mask.eq(1))\n",
    "area_stable = stable_mask \\\n",
    "    .multiply(pixel_area) \\\n",
    "    .reduceRegion(\n",
    "        reducer=ee.Reducer.sum(),\n",
    "        geometry=roi,\n",
    "        scale=10,\n",
    "        maxPixels=1e13\n",
    "    )\n",
    "\n",
    "# ============================================================\n",
    "# Step 3: Fetch & Convert to km²\n",
    "# ============================================================\n",
    "\n",
    "def to_km2(ee_dict, key):\n",
    "    val_m2 = ee_dict.getInfo()[key]\n",
    "    return round(val_m2 / 1e6, 3)   # m² → km²\n",
    "\n",
    "builtup_2016_km2   = to_km2(area_2016,       'BuiltUp')\n",
    "builtup_2025_km2   = to_km2(area_2025,       'BuiltUp')\n",
    "new_growth_km2     = to_km2(area_new_growth, 'BuiltUp')\n",
    "lost_km2           = to_km2(area_lost,       'BuiltUp')\n",
    "stable_km2         = to_km2(area_stable,     'BuiltUp')\n",
    "net_change_km2     = round(new_growth_km2 - lost_km2, 3)\n",
    "pct_change         = round(((builtup_2025_km2 - builtup_2016_km2) / builtup_2016_km2) * 100, 2)\n",
    "\n",
    "# ============================================================\n",
