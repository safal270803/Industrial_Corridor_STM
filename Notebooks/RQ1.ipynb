    "# ============================================================\n",
    "# Built-up Growth Heatmap (2016 vs 2025 Comparison)\n",
    "# ============================================================\n",
    "\n",
    "# Step 1: Create the Change Map\n",
    "# Logic:\n",
    "#   mask_2016 = 1, built_up_mask = 0  → Lost built-up (unlikely but possible)\n",
    "#   mask_2016 = 0, built_up_mask = 1  → NEW growth (2016→2025)\n",
    "#   mask_2016 = 1, built_up_mask = 1  → Stable built-up (existed in both)\n",
    "#   mask_2016 = 0, built_up_mask = 0  → Non built-up (no change)\n",
    "\n",
    "# Encode into a single band:\n",
    "# 0 = No built-up (both years)\n",
    "# 1 = Stable built-up (both years)\n",
    "# 2 = New growth (only in 2025)\n",
    "# 3 = Lost built-up (only in 2016) ← rare, useful for QA\n",
    "\n",
    "change_map = (\n",
    "    mask_2016.rename('y2016')\n",
    "    .addBands(built_up_mask.rename('y2025'))\n",
    ")\n",
    "\n",
    "# Classify into 4 categories\n",
    "growth_class = change_map.expression(\n",
    "    \"(b('y2016') == 0 && b('y2025') == 0) ? 0 \"   # No built-up\n",
    "    \": (b('y2016') == 1 && b('y2025') == 1) ? 1 \"  # Stable\n",
    "    \": (b('y2016') == 0 && b('y2025') == 1) ? 2 \"  # New Growth ✅\n",
    "    \": 3\"                                            # Lost (QA check)\n",
    ").rename('GrowthClass')\n",
    "\n",
    "# ============================================================\n",
    "# Step 2: Visualize as Heatmap\n",
    "# ============================================================\n",
    "\n",
    "# Color palette:\n",
    "# 0 → Transparent/Black  = No built-up\n",
    "# 1 → Gray               = Stable built-up (existed in 2016 & 2025)\n",
    "# 2 → Red/Orange         = NEW growth (2025 only) ← the key insight\n",
    "# 3 → Blue               = Lost built-up (2016 only)\n",
    "\n",
    "growth_palette = {\n",
    "    'min': 0,\n",
    "    'max': 3,\n",
    "    'palette': ['1a1a1a', '888888', 'ff4500', '1e90ff']\n",
    "    #            Black     Gray      OrangeRed  DodgerBlue\n",
    "}\n",
    "\n",
    "Map = geemap.Map()\n",
    "Map.centerObject(roi, 11)\n",
    "\n",
    "# Base reference layer\n",
    "Map.addLayer(s2, {'bands': ['B4', 'B3', 'B2'], 'min': 0, 'max': 3000}, \n",
    "             'S2 True Color (2025)', shown=False)\n",
    "\n",
    "# Individual masks for reference\n",
    "Map.addLayer(mask_2016, {'min': 0, 'max': 1, 'palette': ['000000', 'ffffff']}, \n",
    "             '2016 Built-up', shown=False)\n",
    "Map.addLayer(built_up_mask, {'min': 0, 'max': 1, 'palette': ['000000', 'ffffff']}, \n",
    "             '2025 Built-up', shown=False)\n",
    "\n",
    "# ✅ The main heatmap\n",
    "Map.addLayer(growth_class, growth_palette, '🔥 Built-up Growth Heatmap (2016–2025)')\n",
    "\n",
    "# ============================================================\n",
    "# Step 3: Add a Legend\n",
    "# ============================================================\n",
    "legend_dict = {\n",
    "    'No Built-up (Both Years)':     '1a1a1a',\n",
    "    'Stable Built-up (2016 & 2025)':'888888',\n",
    "    '🔴 New Growth (2025 Only)':    'ff4500',\n",
    "    '🔵 Lost Built-up (2016 Only)': '1e90ff',\n",
    "}\n",
    "Map.add_legend(title='Built-up Change 2016–2025', legend_dict=legend_dict)\n",
    "\n",
    "Map"
