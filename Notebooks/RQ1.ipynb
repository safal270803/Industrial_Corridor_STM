    "\n",
    "# ============================================================\n",
    "# 2. ROAD ACCESSIBILITY — Hierarchy + Sigmoid Decay\n",
    "# ============================================================\n",
    "\n",
    "# --- 2a. Build weighted road raster, reprojected to UTM ---\n",
    "road_imgs = []\n",
    "for hw_type, hw_weight in ROAD_WEIGHTS.items():\n",
    "    filtered = ee_roads.filter(ee.Filter.eq('highway', hw_type))\n",
    "    img = (\n",
    "        ee.Image(0).float()\n",
    "        .paint(filtered, hw_weight)\n",
    "        .reproject(crs=CRS, scale=SCALE)\n",
    "    )\n",
    "    road_imgs.append(img)\n",
    "\n",
    "road_weighted = ee.ImageCollection(road_imgs).max()\n",
    "\n",
    "# --- 2b. Distance transform (pixels → meters) ---\n",
    "road_dist_m = (\n",
    "    road_weighted\n",
    "    .fastDistanceTransform(neighborhood=NEIGHBORHOOD)\n",
    "    .sqrt()\n",
    "    .multiply(SCALE)\n",
    "    .reproject(crs=CRS, scale=SCALE)\n",
    ")\n",
    "\n",
    "# --- 2c. Sigmoid decay ---\n",
    "# Stays near 1.0 close to roads, drops sharply beyond SIGMOID_CENTER\n",
    "road_access = road_dist_m.expression(\n",
    "    '1.0 / (1.0 + exp(k * (d - c)))',\n",
    "    {\n",
    "        'd': road_dist_m,\n",
    "        'c': SIGMOID_CENTER,\n",
    "        'k': SIGMOID_STEEPNESS,\n",
    "    }\n",
    ").clamp(0, 1).rename('road_access')\n",
    "\n",
    "\n",
    "# ============================================================\n",
    "# 3. INFRA ACCESSIBILITY — Exponential Decay + Agglomeration Sum\n",
    "# Based on Weber's Economic Geography Logic (Agglomoration)\n",
    "# ============================================================\n",
    "\n",
    "def create_infra_raster(feature):\n",
    "    w    = ee.Number(feature.get('weight'))\n",
    "    tier = ee.Number(feature.get('tier'))\n",
    "\n",
    "    decay_const = ee.Number(\n",
    "        ee.Algorithms.If(tier.eq(2), DECAY_TIER2, DECAY_TIER1)\n",
    "    )\n",
    "\n",
    "    infra_mask = (\n",
    "        ee.Image(0).float()\n",
    "        .paint(ee.FeatureCollection([feature]), 1)\n",
    "        .reproject(crs=CRS, scale=SCALE)\n",
    "    )\n",
    "\n",
    "    d_img = (\n",
    "        infra_mask\n",
    "        .fastDistanceTransform(neighborhood=NEIGHBORHOOD)\n",
    "        .sqrt()\n",
    "        .multiply(SCALE)\n",
    "        .reproject(crs=CRS, scale=SCALE)\n",
    "    )\n",
    "\n",
    "    decay_img = d_img.expression(\n",
    "        'w * exp(-d / sigma)',\n",
    "        {\n",
    "            'w':     w,\n",
    "            'd':     d_img,\n",
    "            'sigma': decay_const,\n",
    "        }\n",
    "    ).rename('infra')\n",
    "\n",
    "    return decay_img.float()\n",
    "\n",
    "\n",
    "# --- Agglomeration sum, normalized by node count so it doesn't saturate ---\n",
    "infra_decay_images = infra_fc.map(create_infra_raster)\n",
    "infra_raw = ee.ImageCollection(infra_decay_images).sum()\n",
    "\n",
    "# Normalize: divide by total node count so clustered areas score high\n",
