  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "f83c6eb7-60e8-4f25-bf12-ade7887d867d",
   "metadata": {},
   "outputs": [],
   "source": [
    "# 3: GEE Raster Preparation ---\n",
    "\n",
    "# Distance Raster (Threshold at 20km)\n",
    "# The distance is calculated in the cloud based on the geometry of ee_roads\n",
    "dist_raster = ee_roads.distance(20000).rename('dist_m')\n",
    "\n",
    "# Built-up Density (Neighborhood scale 250m)\n",
    "# .toFloat() ensures we get decimal density gradients (0.0 to 1.0)\n",
    "density_raster = built_up_mask.toFloat().focal_mean(radius=250, units='meters').rename('builtup_density')\n",
    "\n",
    "# Stack Bands into a single 'Analysis Image'\n",
    "data_stack = dist_raster.addBands(density_raster)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "00ec5022-cf95-42fa-a5a2-676960541e98",
   "metadata": {},
   "source": [
    "2000 random points are created here inside the roi (Dholera_Taluk Region), with seed = 42"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "3a81e176-77d9-411c-87a8-6a88a00205b6",
   "metadata": {},
   "outputs": [],
   "source": [
    "# 4: Sampling & Export ---\n",
    "\n",
    "# 1. Generate 2000 Random \"Survey\" Points inside the ROI\n",
    "sample_points = ee.FeatureCollection.randomPoints(region=roi, points=2000, seed=42)\n",
    "\n",
    "# 2. ReduceRegions: The \"Engine Room\"\n",
    "# We specify the CRS here to ensure 'dist_m' is interpreted as meters\n",
    "sampled_fc = data_stack.reduceRegions(\n",
    "    collection=sample_points,\n",
    "    reducer=ee.Reducer.first(),\n",
    "    scale=10,\n",
    "    crs='EPSG:32643' #Based on Dholera location\n",
    ")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "2b3f37a5-9a47-4c1b-93ed-0fb5116602a2",
   "metadata": {},
   "source": [
    "Code section below will take time, because it is loading those 2000 points data in local memory. \n",
    "You can ideally skip it if you don't want to wait much, as I have provided csv data separately in data folder. \n",
    "Just run the code below this code block."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "625770a3-ed5e-426a-9c3e-b35f48ff868f",
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\" Extracting data and coordinates...\")\n",
    "\n",
    "# Get the raw data (which includes geometry)\n",
    "raw_data = sampled_fc.getInfo()['features']\n",
    "\n",
    "# Extract properties AND coordinates manually\n",
    "data_list = []\n",
    "for f in raw_data:\n",
    "    props = f['properties']\n",
    "    # Grab coordinates from the geometry key\n",
    "    props['longitude'] = f['geometry']['coordinates'][0]\n",
    "    props['latitude'] = f['geometry']['coordinates'][1]\n",
    "    data_list.append(props)\n",
    "\n",
    "# Create DataFrame\n",
    "df_2025 = pd.DataFrame(data_list)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "61038151-8d14-4897-b463-bd9aa91d924c",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Final Cleaning\n",
    "# Remove points that might have landed in 'No Data' zones\n",
    "df_2025 = df_2025.dropna(subset=['dist_m', 'builtup_density'])\n",
    "\n",
    "print(f\"Success! Final dataset contains {len(df_2025)} points.\")\n",
    "print(df_2025.head())"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "15be2918-4116-4cf4-9f94-f1bf16652893",
   "metadata": {},
   "source": [
    "This is a pure code just for the purpose to export to the drive. You can skip this, as I have provided you the .csv file for you to save your time in the code sections below."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "f8c5cdf8-0804-49a7-853d-eb441fbf38a2",
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- STEP: ADD COORDINATES & EXPORT ---\n",
    "\n",
    "# 1. Function to pull Lat/Lon out of the geometry and into properties (columns)\n",
    "def add_lat_lon(feature):\n",
    "    coords = feature.geometry().coordinates()\n",
    "    return feature.set({\n",
    "        'longitude': coords.get(0),\n",
    "        'latitude': coords.get(1)\n",
    "    })\n",
    "\n",
    "# 2. Map the function over your collection\n",
    "final_export_fc = sampled_fc.map(add_lat_lon)\n",
    "\n",
    "# 3. Start the Export Task\n",
    "task = ee.batch.Export.table.toDrive(\n",
    "    collection=final_export_fc,\n",
    "    description='Dholera_Sampling_2025_Final',\n",
    "    folder='export',\n",
    "    fileNamePrefix='dholera_samples_with_coords',\n",
    "    fileFormat='CSV',\n",
    "    selectors=['latitude', 'longitude', 'dist_m', 'builtup_density'] # Define column order\n",
    ")\n",
    "\n",
    "task.start()\n",
    "\n",
    "print(\"Export Task started!\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "c4f24511-1373-416b-a755-d493d95e7789",
   "metadata": {},
   "source": [
